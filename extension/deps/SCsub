#!/usr/bin/env python

Import("env")


def build_openvic_simulation(env):
    ovsim_env = SConscript(
        "openvic-simulation/SConstruct", exports={"build_dir": env["build_dir"] + "/openvic-simulation"}
    )
    env.AppendUnique(CPPDEFINES=ovsim_env["CPPDEFINES"])
    env.AddLibraryIncludes(ovsim_env.exposed_includes)
    env.Append(LIBPATH=ovsim_env["LIBPATH"])
    env.Prepend(LIBS=ovsim_env["LIBS"])


def build_gli(env):
    env.AddLibraryIncludes(["gli", "gli/external"])


build_openvic_simulation(env)
build_gli(env)
